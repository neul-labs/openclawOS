{
  "id": "@openclawos/slack",
  "name": "Slack Channel",
  "version": "0.1.0",
  "description": "Slack workspace integration via Bolt SDK",
  "type": "app",
  "main": "dist/index.js",
  "protocol": {
    "version": "1.0"
  },
  "capabilities": {
    "channels": {
      "provides": ["slack"]
    },
    "hooks": {
      "subscribes": ["message_sending"]
    },
    "resources": {
      "env": ["SLACK_BOT_TOKEN", "SLACK_APP_TOKEN"],
      "network": {
        "hosts": ["slack.com", "api.slack.com", "wss-primary.slack.com"]
      }
    }
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "botToken": {
        "type": "string",
        "description": "Slack bot OAuth token (xoxb-...)"
      },
      "appToken": {
        "type": "string",
        "description": "Slack app-level token for socket mode (xapp-...)"
      },
      "mode": {
        "type": "string",
        "enum": ["socket", "http"],
        "description": "Connection mode (socket or http)"
      },
      "signingSecret": {
        "type": "string",
        "description": "Slack signing secret (required for HTTP mode)"
      }
    }
  },
  "configUiHints": {
    "botToken": {
      "label": "Bot Token",
      "sensitive": true,
      "description": "OAuth bot token from Slack app settings"
    },
    "appToken": {
      "label": "App Token",
      "sensitive": true,
      "description": "App-level token for socket mode"
    },
    "mode": {
      "label": "Connection Mode",
      "description": "Socket mode (recommended) or HTTP webhooks"
    },
    "signingSecret": {
      "label": "Signing Secret",
      "sensitive": true,
      "description": "Required for HTTP mode verification",
      "advanced": true
    }
  }
}
