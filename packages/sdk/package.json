{
  "name": "@openclawos/sdk",
  "version": "0.1.0",
  "description": "OpenClawOS SDK for building apps, skills, agents, and extensions",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./app": {
      "types": "./dist/app.d.mts",
      "default": "./dist/app.mjs"
    },
    "./skill": {
      "types": "./dist/skill.d.mts",
      "default": "./dist/skill.mjs"
    },
    "./agent": {
      "types": "./dist/agent.d.mts",
      "default": "./dist/agent.mjs"
    },
    "./extension": {
      "types": "./dist/extension.d.mts",
      "default": "./dist/extension.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "default": "./dist/testing.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openclawos/protocol": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
